# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
FLASK_SECRET_KEY=change-me-use-openssl-rand-hex-32

# App
ENV=development
APP_URL=http://localhost:8080
PORT=8080
DATABASE_PATH=real_estate.db

# Stripe (required in production) 
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Set to false to skip subscription checks in local dev
SUBSCRIPTION_REQUIRED=true

# Comma-separated emails that can access the app without a paid Stripe subscription.
# Example: demo1@example.com,demo2@example.com
FREE_ACCESS_EMAILS=
